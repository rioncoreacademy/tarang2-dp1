{
  "name": "ChipCraft Lab — Digital Design & VLSI",
  "build": {
    "dockerfile": "../Dockerfile"
  },
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "Lab Desktop (noVNC)",
      "onAutoForward": "openBrowser",
      "protocol": "http"
    }
  },
  "postStartCommand": "bash ${containerWorkspaceFolder}/.devcontainer/single-user/start.sh",
  "remoteUser": "ubuntu"
}
